{
  "name": "@fluxguard/runtime",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./*": null
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "dependencies": {
    "@fluxguard/contracts": "workspace:*",
    "ioredis": "^5.10.1"
  },
  "scripts": {
    "build": "pnpm typecheck && tsup",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "rate-limit",
    "rate-limiter",
    "redis",
    "nestjs",
    "throttling",
    "gcra"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/fluxguard.git"
  },
  "homepage": "https://github.com/your-org/fluxguard",
  "bugs": {
    "url": "https://github.com/your-org/fluxguard/issues"
  }
}
