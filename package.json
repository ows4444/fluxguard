{
  "name": "fluxguard-monorepo",
  "private": true,
  "packageManager": "pnpm@11.0.3",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "turbo run build",
    "clean": "turbo run clean",
    "clean:full": "turbo run clean && rimraf node_modules",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "build:packages": "turbo run build --filter='./packages/*'",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "only-allow": "^1.2.2",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.9.12",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/fluxguard.git"
  },
  "homepage": "https://github.com/your-org/fluxguard",
  "bugs": {
    "url": "https://github.com/your-org/fluxguard/issues"
  }
}
