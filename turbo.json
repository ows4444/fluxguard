{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {
    "build": {
      "dependsOn": ["^build", "^typecheck"],
      "outputs": ["dist/**", "dist/.tsbuildinfo"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "lint": {
      "outputs": []
    },

    "lint:fix": {
      "cache": false,
      "outputs": []
    },

    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },

    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },

    "clean": {
      "cache": false
    }
  }
}
